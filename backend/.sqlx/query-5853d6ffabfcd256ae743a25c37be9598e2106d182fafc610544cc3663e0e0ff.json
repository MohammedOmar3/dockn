  "query": "\n        SELECT t.id, t.user_id, t.name, t.color, t.created_at\n        FROM tags t\n        JOIN task_tags tt ON tt.tag_id = t.id\n        WHERE tt.task_id = $1\n        ORDER BY t.name\n        ",
