{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT tt.task_id,\n               t.id AS tag_id, t.user_id AS tag_user_id,\n               t.name, t.color, t.created_at AS tag_created_at\n        FROM task_tags tt\n        JOIN tags t ON t.id = tt.tag_id\n        WHERE tt.task_id = ANY($1)\n        ORDER BY t.name\n        ",
