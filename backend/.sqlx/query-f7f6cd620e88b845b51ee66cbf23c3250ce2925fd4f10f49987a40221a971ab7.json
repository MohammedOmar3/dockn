  "query": "\n        UPDATE whiteboards\n        SET\n            title     = COALESCE($1, title),\n            folder_id = COALESCE($2, folder_id),\n            raw_data  = COALESCE($3, raw_data)\n        WHERE id = $4 AND user_id = $5\n        RETURNING *\n        ",
