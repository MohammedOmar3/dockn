  "query": "\n            SELECT id, log_date,\n                   LEFT(content::TEXT, 150) AS \"content_snippet!\"\n            FROM daily_logs\n            WHERE user_id = $1 AND content::TEXT ILIKE $2\n            ORDER BY log_date DESC\n            LIMIT 10\n            ",
