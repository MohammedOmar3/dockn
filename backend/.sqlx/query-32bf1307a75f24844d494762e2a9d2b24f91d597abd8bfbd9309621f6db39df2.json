  "query": "\n        UPDATE notes\n        SET\n            title         = COALESCE($1, title),\n            content       = COALESCE($2, content),\n            notebook_id   = COALESCE($3, notebook_id),\n            display_order = COALESCE($4, display_order)\n        WHERE id = $5 AND user_id = $6\n        RETURNING *\n        ",
