{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT id, user_id, title, description,\n               status AS \"status: TaskStatus\",\n               priority AS \"priority: TaskPriority\",\n               due_date, created_at, updated_at\n        FROM tasks\n        WHERE user_id = $1\n        ORDER BY\n            CASE priority\n                WHEN 'urgent' THEN 0\n                WHEN 'high'   THEN 1\n                WHEN 'medium' THEN 2\n                ELSE               3\n            END,\n            due_date ASC NULLS LAST,\n            created_at DESC\n        ",
